# ============================================================
# AI Hiring Copilot — Environment Variables
# Copy this file to .env and fill in values. Never commit .env
# ============================================================

# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hiring_copilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=ai-hiring-copilot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=ai-hiring-copilot-resumes
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account-id/resume-processing-queue
AWS_SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/account-id/resume-processing-dlq

# Anthropic (fallback LLM)
ANTHROPIC_API_KEY=sk-ant-...

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Hiring Copilot
NEXT_PUBLIC_APP_URL=http://localhost:3000
